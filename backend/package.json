{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --poll --files src/index.ts index.d.ts",
    "start": "node dist/src/index.js",
    "lint": "eslint ./src",
    "build": "rimraf dist && tsc",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "seed": "ts-node -r dotenv/config src/seeds/index.ts",
    "seed:fresh": "ts-node -r dotenv/config src/seeds/index.ts --fresh",
    "seed:users": "ts-node -r dotenv/config src/seeds/userSeeder.ts",
    "seed:users:fresh": "ts-node -r dotenv/config src/seeds/userSeeder.ts --fresh",
    "seed:clear": "ts-node -r dotenv/config src/seeds/clearAll.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/socket.io": "^3.0.1",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.2",
    "multer": "^1.4.5-lts.1",
    "resend": "^3.2.0",
    "serverless-http": "^3.2.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "zod": "^3.23.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^17.0.0",
    "jest-stare": "^2.5.3",
    "rimraf": "^5.0.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
